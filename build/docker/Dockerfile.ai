# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile.ai — Osmedeus AI Scanner (all security tools pre-installed)
#
# Multi-stage build using pre-built binaries from official images:
#   - ProjectDiscovery tools: nuclei, subfinder, httpx, dnsx, naabu
#   - OWASP Amass, ffuf, gau
#   - Osmedeus compiled from source
#
# Build time: ~2-3 minutes (vs 10-15 min when compiling tools from source)
#
# Build:
#   docker build -f build/docker/Dockerfile.ai -t osmedeus-ai .
#
# Run:
#   docker run -e OPENAI_API_KEY=sk-xxx -p 8002:8002 osmedeus-ai
# ─────────────────────────────────────────────────────────────────────────────

# ── Pre-built tool images (official sources) ─────────────────────────────────
FROM projectdiscovery/nuclei:latest    AS nuclei
FROM projectdiscovery/subfinder:latest AS subfinder
FROM projectdiscovery/httpx:latest     AS httpx
FROM projectdiscovery/dnsx:latest      AS dnsx
FROM projectdiscovery/naabu:latest     AS naabu
FROM caffix/amass:latest               AS amass

# ── Stage: osmedeus builder ──────────────────────────────────────────────────
FROM golang:1.26-bookworm AS builder

ARG BUILD_TIME
ARG COMMIT_HASH

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build \
    -ldflags "-X main.BuildTime=${BUILD_TIME} -X main.CommitHash=${COMMIT_HASH}" \
    -o /osmedeus ./cmd/osmedeus

# Install lightweight Go tools not available as Docker images
RUN go install github.com/tomnomnom/waybackurls@latest && \
    go install github.com/tomnomnom/httprobe@latest && \
    go install github.com/ffuf/ffuf/v2@latest && \
    go install github.com/lc/gau/v2/cmd/gau@latest

# ── Stage: runtime ───────────────────────────────────────────────────────────
FROM debian:bookworm-slim

LABEL maintainer="osmedeus"
LABEL description="Osmedeus AI Scanner — all security tools pre-installed"
LABEL org.opencontainers.image.source="https://github.com/j3ssie/osmedeus"

# ── Core system packages ─────────────────────────────────────────────────────
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 python3-pip python3-venv \
        dnsutils whois curl wget \
        libpcap-dev git jq ca-certificates \
        nmap masscan chromium perl \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3 /usr/bin/python

# ── Pip packages ─────────────────────────────────────────────────────────────
RUN python3 -m pip install --no-cache-dir --break-system-packages sslyze sqlmap

# ── nikto (not in Debian bookworm repos) ─────────────────────────────────────
RUN git clone --depth 1 https://github.com/sullo/nikto /opt/nikto && \
    ln -sf /opt/nikto/program/nikto.pl /usr/local/bin/nikto && \
    chmod +x /opt/nikto/program/nikto.pl

# ── testssl.sh (not available via apt) ───────────────────────────────────────
RUN git clone --depth 1 https://github.com/drwetter/testssl.sh /opt/testssl.sh && \
    ln -sf /opt/testssl.sh/testssl.sh /usr/local/bin/testssl.sh

# ── Copy osmedeus binary ─────────────────────────────────────────────────────
COPY --from=builder /osmedeus /usr/local/bin/osmedeus

# ── Copy pre-built security tools from official images ───────────────────────
COPY --from=nuclei    /usr/local/bin/nuclei    /usr/local/bin/nuclei
COPY --from=subfinder /usr/local/bin/subfinder /usr/local/bin/subfinder
COPY --from=httpx     /usr/local/bin/httpx     /usr/local/bin/httpx
COPY --from=dnsx      /usr/local/bin/dnsx      /usr/local/bin/dnsx
COPY --from=naabu     /usr/local/bin/naabu     /usr/local/bin/naabu
COPY --from=amass     /bin/amass               /usr/local/bin/amass

# ── Copy Go tools compiled in builder ────────────────────────────────────────
COPY --from=builder /go/bin/waybackurls /usr/local/bin/waybackurls
COPY --from=builder /go/bin/httprobe    /usr/local/bin/httprobe
COPY --from=builder /go/bin/ffuf        /usr/local/bin/ffuf
COPY --from=builder /go/bin/gau         /usr/local/bin/gau

# ── Create base directory structure ──────────────────────────────────────────
RUN mkdir -p /root/osmedeus-base/output \
             /root/osmedeus-base/sessions \
             /root/osmedeus-base/nuclei-templates \
             /root/workspaces-osmedeus

WORKDIR /root

# ── Copy workflow assets from source ─────────────────────────────────────────
COPY workflows/  /root/osmedeus-base/workflows/
COPY prompts/    /root/osmedeus-base/prompts/
COPY public/     /root/osmedeus-base/public/

# ── Bootstrap nuclei templates ───────────────────────────────────────────────
RUN nuclei -update-templates -silent 2>/dev/null || true

# ── Environment variables ────────────────────────────────────────────────────
ENV PATH="/usr/local/go/bin:/usr/local/bin:/root/go/bin:/root/osmedeus-base/external-binaries:${PATH}" \
    OSMEDEUS_BASE="/root/osmedeus-base" \
    PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH="/usr/bin/chromium"

# ── Network ──────────────────────────────────────────────────────────────────
EXPOSE 8002

# ── Health check ─────────────────────────────────────────────────────────────
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD curl -sf http://localhost:8002/health || exit 1

# ── Default command — start API server ───────────────────────────────────────
ENTRYPOINT ["osmedeus"]
CMD ["server"]

